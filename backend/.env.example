# Copy this file to .env and adjust values for your environment.
# .env itself should NEVER be committed to git (it's already in .gitignore).

# --- Server ---
HOST=0.0.0.0
PORT=8000
RELOAD=true

# --- CORS: comma-separated list of allowed frontend origins ---
# For local dev with the React app on port 3000:
ALLOWED_ORIGINS=http://localhost:3000

# --- Risk classification thresholds (0.0 - 1.0) ---
RISK_THRESHOLD_SUSPECT=0.33
RISK_THRESHOLD_HIGH=0.66

# --- Model training ---
DL_EPOCHS=150
DL_LEARNING_RATE=0.005
DL_BATCH_SIZE=512
RANDOM_SEED=42
