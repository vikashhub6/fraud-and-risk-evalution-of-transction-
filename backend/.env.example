# Copy this file to .env and adjust values for your environment.
# .env itself should NEVER be committed to git (it's already in .gitignore).

# --- Server ---
HOST=0.0.0.0
PORT=****
RELOAD=true

# --- CORS: comma-separated list of allowed frontend origins ---
# For local dev with the React app on port 3000:
ALLOWED_ORIGINS=*****

# --- Risk classification thresholds (0.0 - 1.0) ---
RISK_THRESHOLD_SUSPECT=***
RISK_THRESHOLD_HIGH=***

# --- Model training ---
DL_EPOCHS=***
DL_LEARNING_RATE=****
DL_BATCH_SIZE=****
RANDOM_SEED=****
